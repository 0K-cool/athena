# ATHENA Dashboard — Configuration
# Copy to .env and adjust as needed

# ── Neo4j ──
# Primary: Antsle (always-on cloud)
NEO4J_URI=bolt://your-kali-host:7687
NEO4J_USER=neo4j
NEO4J_PASS=$NEO4J_PASS

# Fallback: Mini-PC (ZeroTier, air-gapped)
# NEO4J_URI=bolt://your-internal-kali:7687

# ── Kali Backends (Phase C) ──
# External: Antsle cloud (always-on, no API key)
KALI_EXTERNAL_URL=http://your-kali-host:5000

# Internal: Mini-PC on-premise (ZeroTier VPN, API key required)
KALI_INTERNAL_URL=http://your-internal-kali:5000
KALI_API_KEY=
